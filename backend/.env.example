# Copy to .env for local overrides. Without POSTGRES_DB/REDIS_URL the backend
# boots on SQLite + in-memory channel layer + eager Celery (zero infra).

DJANGO_SECRET_KEY=dev-secret-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (matches docker-compose.yml)
POSTGRES_DB=nomnom
POSTGRES_USER=nomnom
POSTGRES_PASSWORD=nomnom
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis (Channels + Celery)
REDIS_URL=redis://127.0.0.1:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
