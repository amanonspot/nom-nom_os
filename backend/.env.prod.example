# Copy to .env.prod for the production stack (docker-compose.prod.yml).
# Generate a real secret: python -c "import secrets; print(secrets.token_urlsafe(50))"

DJANGO_SECRET_KEY=change-me-to-a-long-random-value
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-domain.com,api.your-domain.com

# Postgres
POSTGRES_DB=nomnom
POSTGRES_USER=nomnom
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis (Channels layer + Celery). Required in production for realtime.
REDIS_URL=redis://redis:6379/0

# CORS: the deployed frontend origins.
CORS_ALLOWED_ORIGINS=https://pos.your-domain.com,https://admin.your-domain.com,https://kds.your-domain.com
